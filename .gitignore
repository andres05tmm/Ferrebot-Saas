# Python
__pycache__/
*.py[cod]
.venv/
venv/
# Entorno / secretos
.env
.env.*
!.env.example
# plantilla de ops (sin secretos); el .env.prod real SÍ se ignora (lo cubre .env.*)
!.env.prod.example
# Node / frontend
node_modules/
dashboard/dist/
landing/dist/
.scratch-logo/
# Onboarding: valores REALES por empresa (secretos en claro) — nunca commitear.
# Solo se versionan las plantillas *.example.{json,yaml} (incl. manifiestos, ADR 0007).
tools/onboarding/*.json
!tools/onboarding/empresa.example.json
tools/onboarding/*.yaml
!tools/onboarding/*.example.yaml
# Insumos dorados del eval (ADR 0011 §D7): fotos/Excel/CSV REALES del catálogo + reportes de corrida.
# Llevan datos reales del cliente (precios) — nunca commitear; viven junto a los manifiestos.
tools/onboarding/*.csv
tools/onboarding/*.xlsx
tools/onboarding/*.jpg
tools/onboarding/*.jpeg
tools/onboarding/*.png
tools/onboarding/*.webp
tools/onboarding/*.pdf
eval-*.md
eval-*.json
# Respaldos de prod (los .dump llevan datos reales + secretos cifrados) — nunca commitear.
backups/
# Replay del eval: el CÓDIGO del rig (runner/extractores/tests/seed) sí se versiona, pero los datos
# REALES del tenant (catálogo/corpus reconstruidos del dump) y los reportes de corrida NO (precios
# reales del cliente). Se regeneran con `extraer_catalogo.py`/`extraer_corpus.py` desde el dump local.
tests/evals/replay/catalogo_*.json
tests/evals/replay/corpus_puntorojo.jsonl
tests/evals/replay/corpus_mensajes.jsonl
tests/evals/replay/reporte*.json
/reporte_*.json
/catalogo_*.json
/pytest_*.txt
/unidades_tmp.txt
# CodeGraph: indice local de codigo (SQLite, se reconstruye con `codegraph init`).
.codegraph/
# Varios
.DS_Store
*.log
# Logs de corridas de test y scratch local (no ensuciar el repo).
*.out
_scratch_verify.py
screen.png
# Cobertura y locks locales (uv.lock SÍ se versiona).
.coverage
*.lock
!uv.lock
