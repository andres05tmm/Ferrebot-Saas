# ─────────────────────────────────────────────────────────────
# Plataforma (variables globales del SaaS) — mapeo 1:1 con core/config/settings.py
# Forma base de las URLs Postgres: postgresql://user:pass@host:port/db
# (los drivers async/sync se derivan en core/db/urls.py)
# ─────────────────────────────────────────────────────────────
ADMIN_DATABASE_URL=postgresql://user:pass@host:5432/postgres        # DB de mantenimiento: CREATE DATABASE al provisionar
CONTROL_DATABASE_URL=postgresql://user:pass@host:5432/control       # control DB (empresas, planes, branding, secretos)
TENANTS_DIRECT_URL_BASE=postgresql://user:pass@host:5432            # base SIN /db: se compone {base}/ferrebot_<slug> por empresa

SECRET_KEY=                      # firma de JWT (GENERAR para prod; no reusar la local)
SECRETS_MASTER_KEY=              # cifra los secretos por empresa (GENERAR para prod; NO commitear)
BASE_DOMAIN=app.tudominio.com    # subdominios: <slug>.app.tudominio.com → empresa
# DEFAULT_TENANT_SLUG=puntorojo  # OPT-IN single-tenant: empresa por defecto si no hay subdominio/header/JWT
                                 # (deploy sin dominio propio). Vacío = multi-tenant normal. Ver docs/fase-14.
SERVICE_TYPE=api                 # api | bot | worker (selecciona el proceso del entrypoint)
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=

# Auth (opcionales; tienen default en settings.py)
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=720

# IA (plataforma; el costo se mide por empresa)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Canal WhatsApp vía Kapso (BSP) — credenciales de PLATAFORMA (una cuenta para todos los tenants).
# KAPSO_WEBHOOK_SECRET: firma HMAC-SHA256 de los webhooks entrantes (header X-Webhook-Signature).
# KAPSO_API_KEY: Project API key para el envío saliente (header X-API-Key). Ver docs.kapso.ai.
KAPSO_WEBHOOK_SECRET=
KAPSO_API_KEY=
# KAPSO_API_BASE=https://api.kapso.ai/meta/whatsapp/v24.0
# LLM_PROVIDER=openai
# LLM_MODEL_WORKER=gpt-4o-mini
# LLM_MODEL_ORQUESTADOR=gpt-4o
# Gobierno de agentes (ADR 0024): compuertas Redis antes de gastar la llamada al modelo. 0 = apagado
# (opt-in); override por empresa en config_empresa; GOBIERNO_HABILITADO es el kill-switch en caliente.
# GOBIERNO_HABILITADO=true
# GOBIERNO_RATE_LIMITE=0
# GOBIERNO_RATE_VENTANA_S=60
# GOBIERNO_PRESUPUESTO_DIARIO=0
# GOBIERNO_COSTO_ESTIMADO_TURNO=1500

# ─────────────────────────────────────────────────────────────
# Por empresa: NO van aquí.
# MATIAS_*, CLOUDINARY_*, TELEGRAM_TOKEN, resolución/consecutivos DIAN, matias_ambiente
# y branding se guardan CIFRADOS en el control DB (tabla secretos_empresa / config_empresa).
# Ver SECURITY.md y docs/onboarding-tenant.md
# ─────────────────────────────────────────────────────────────

# Entorno de despliegue: "production" en Railway activa el fail-fast de claves
# (aborta el arranque si SECRET_KEY/SECRETS_MASTER_KEY siguen en su default de dev).
ENTORNO=dev
