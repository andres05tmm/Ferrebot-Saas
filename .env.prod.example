# ─────────────────────────────────────────────────────────────
# .env.prod — entorno de OPERACIÓN contra PRODUCCIÓN (Railway).
#
# Copia este archivo a `.env.prod` (NO se commitea: lleva password + master key) y rellena con las
# URLs PÚBLICAS de Railway. Lo usan los tools de ops (tools/backup_db.py) vía tools/_prodenv.py para
# pegarle a prod en vez del Postgres local del `.env`.
#
# Las URLs públicas de Railway tienen forma:
#   postgresql://postgres:<PASSWORD>@<PROYECTO>.proxy.rlwy.net:<PUERTO>/<DB>
# (Railway → servicio Postgres → pestaña "Connect" → "Public Network".)
# ─────────────────────────────────────────────────────────────

# DB de mantenimiento (CREATE DATABASE). Suele ser la 'railway' o 'postgres'.
ADMIN_DATABASE_URL=postgresql://postgres:CHANGE_ME@PROYECTO.proxy.rlwy.net:PUERTO/railway

# Control DB (empresas, planes, branding, secretos cifrados).
CONTROL_DATABASE_URL=postgresql://postgres:CHANGE_ME@PROYECTO.proxy.rlwy.net:PUERTO/railway

# Base SIN /db: se compone {base}/ferrebot_<slug> por empresa (igual que en local).
TENANTS_DIRECT_URL_BASE=postgresql://postgres:CHANGE_ME@PROYECTO.proxy.rlwy.net:PUERTO

# La MISMA master key con la que se cifraron los secretos en prod (si no, el dump del control DB
# trae secretos que no podrás descifrar al restaurar). NUNCA commitear.
SECRETS_MASTER_KEY=CHANGE_ME_LA_MASTER_KEY_DE_PROD
