# ─────────────────────────────────────────────────────────────
# Plataforma (variables globales del SaaS)
# ─────────────────────────────────────────────────────────────
CONTROL_DATABASE_URL=postgresql://user:pass@host:5432/control
SECRET_KEY=                      # firma de JWT
SECRETS_MASTER_KEY=              # cifra los secretos por empresa (NO commitear)
BASE_DOMAIN=app.tudominio.com    # subdominios: empresa.app.tudominio.com
SERVICE_TYPE=api                 # api | bot
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=

# IA (plataforma; el costo se mide por empresa)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Por empresa: NO van aquí.
# MATIAS_*, CLOUDINARY_*, TELEGRAM_TOKEN, resolución/consecutivos DIAN
# y branding se guardan CIFRADOS en el control DB (tabla secretos_empresa).
# Ver SECURITY.md y docs/onboarding-tenant.md
# ─────────────────────────────────────────────────────────────
