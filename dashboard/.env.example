# Slug de la empresa para desarrollo local. El SPA lo manda como header X-Tenant-Slug SOLO en dev
# (import.meta.env.DEV); en producción la empresa la resuelve el subdominio y este valor no se usa.
VITE_TENANT_SLUG=puntorojo

# Usuario del bot de Telegram para el Login Widget (sin @). Placeholder; pon el real de la empresa.
VITE_TELEGRAM_BOT_USERNAME=elmicha_bot

# Handoff con la landing (plan Melquiadez §3, M4). En PROD: la landing de sign-in vive en
# melquiadez.com y los tenants en {slug}.melquiadez.com. Sin sesión, el dashboard rebota a la landing.
# Vacío (dev local) = sin landing → el dashboard usa su propio /login. NO setear en dev.
# VITE_LANDING_ORIGIN=https://melquiadez.com   # origin de la landing (login de marca)
# VITE_BASE_DOMAIN=melquiadez.com              # dominio base: {slug}.{BASE_DOMAIN} → tenant
